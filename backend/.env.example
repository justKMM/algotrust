# Copy to .env and replace placeholders (never commit .env).

# Pera Wallet address on Algorand Testnet
RATIONALGO_WALLET_ADDRESS=PASTE_YOUR_PERA_WALLET_ADDRESS_HERE

# Algod API token (empty for public AlgoNode testnet)
RATIONALGO_ALGOD_TOKEN=

# 24-word Pera Universal Wallet seed or legacy 25-word Algorand passphrase (same account)
# Universal Wallet: standard BIP39 (24 words). Legacy: Pera shows 24 words, checksum derived automatically.
RATIONALGO_MNEMONIC=

# Algorand Testnet — switch URL if AlgoNode free quota is exceeded (e.g. Tatum testnet algod)
RATIONALGO_ALGOD_URL=https://testnet-api.algonode.cloud
RATIONALGO_INDEXER_URL=https://testnet-idx.algonode.cloud
RATIONALGO_INDEXER_TOKEN=

# x402 testnet resource (GoPlausible demo — used by spike x402 pay, not the hero demo)
# Hero demo pays local /company/* endpoints while serve is running.
RATIONALGO_X402_PROBE_URL=https://example.x402.goplausible.xyz/avm/weather

# ASA the /company/* x402 seller charges in (testnet USDC default)
RATIONALGO_SETTLEMENT_ASSET_ID=10458941

# API server (Phase 1+)
RATIONALGO_HTTP_ADDR=:8080

# Anthropic API key for the reasoning service (Phase 2+)
RATIONALGO_ANTHROPIC_KEY=
